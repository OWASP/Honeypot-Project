# ==========================================
# CHAMELEON-REN: Environment Variables
# ==========================================

# 1. AWS Configuration
AWS_REGION=eu-north-1 # Change this to your local region (e.g., us-east-1, ap-northeast-1
S3_BUCKET_NAME=chameleon-ren-telemetry-YOUR-UNIQUE-ID

# 2. Threat Intel & Evasion
# Get your free API key from account.shodan.io
SHODAN_API_KEY=your_shodan_api_key_here

# 3. Database Passwords (CHANGE THESE BEFORE DEPLOYMENT)
POSTGRES_PASSWORD=secure_postgres_password_here
MYSQL_ROOT_PASSWORD=secure_mysql_password_here
ODOO_PASSWORD=secure_odoo_password_here
