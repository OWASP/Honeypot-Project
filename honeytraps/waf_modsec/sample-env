# SHODAN_WEBHOOK_URL=
# Run after each poll; JSON on stdin (e.g. copy scripts/shodan_hook.example.sh)
# SHODAN_HOOK_SCRIPT=/app/scripts/shodan_hook.example.sh
# Test-only: SHODAN_FIXTURE_FILE, SHODAN_TEST_PUBLIC_IP, SHODAN_SINGLE_SHOT
